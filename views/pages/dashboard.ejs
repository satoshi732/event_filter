                      <p>Only when enabled will auto mode start the next scan round after the current eligible candidates are exhausted.</p>
                    </div>
                  </label>
                </div>
              </div>

              <div class="auto-rules-column">
                <div class="card-head compact">
                  <h3>Token Rules</h3>
                  <span class="muted">Filter tokens before queueing</span>
