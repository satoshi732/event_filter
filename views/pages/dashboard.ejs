                  <td>
                    <div class="address-inline">
                      <button class="link-btn mono" @click="openToken(row.token.token)">{{ row.token.token }}</button>
                      <button class="icon-copy-btn" type="button" @click="copyAddress(row.token.token)" :aria-label="`Copy ${row.token.token}`" :title="isCopiedAddress(row.token.token) ? 'Copied' : 'Copy address'">
                        <svg v-if="isCopiedAddress(row.token.token)" viewBox="0 0 16 16" aria-hidden="true" class="icon-svg success">
                          <path d="M6.4 11.2 3.2 8l1.1-1.1 2.1 2.1 5.3-5.3L12.8 4z" fill="currentColor"></path>
                        </svg>
                        <svg v-else viewBox="0 0 16 16" aria-hidden="true" class="icon-svg">
                          <path d="M5 2.5A1.5 1.5 0 0 1 6.5 1h6A1.5 1.5 0 0 1 14 2.5v7A1.5 1.5 0 0 1 12.5 11h-1V9.5h1v-7h-6v1H5z" fill="currentColor"></path>
                          <path d="M3.5 5A1.5 1.5 0 0 0 2 6.5v7A1.5 1.5 0 0 0 3.5 15h6A1.5 1.5 0 0 0 11 13.5v-7A1.5 1.5 0 0 0 9.5 5zm0 1.5h6v7h-6z" fill="currentColor"></path>
                        </svg>
                      </button>
                    </div>
                  </td>
                  <td>{{ row.token.token_symbol || '--' }}</td>
                  <td>{{ formatUsd(row.token.token_price_usd) }}</td>
                  <td><span class="chip small" :class="syncStateTone(row.token.token_calls_sync)">{{ syncStateLabel(row.token.token_calls_sync) }}</span></td>
                  <td class="mono">{{ formatTokenAmount(row.current_balance, row.token.decimals) }}</td>
                  <td class="mono">{{ formatTokenAmount(row.transfer_in_amount, row.token.decimals) }}</td>
                  <td class="mono">{{ formatTokenAmount(row.transfer_out_amount, row.token.decimals) }}</td>
                  <td class="mono">{{ formatTokenAmount(row.total_token_flow, row.token.decimals) }}</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <section class="card card-wide" v-if="contractDetail">
          <div class="card-head">
            <h2>Token Asset Flow</h2>
            <span class="muted">{{ sortedContractTokenFlows.length }} counterparties</span>
          </div>
          <div class="filter-toolbar">
            <label class="filter-field">
              <span>Token</span>
              <select v-model="selectedContractFlowToken">
                <option v-for="row in contractFlowTokenOptions" :key="row.token.token" :value="row.token.token">
                  {{ row.token.token_symbol || row.token.token_name || row.token.token }}
                </option>
              </select>
            </label>
            <div v-if="selectedContractFlowTokenRow" class="mini-meta">
              <span>Current Balance</span>
              <strong class="mono">{{ formatTokenAmount(selectedContractFlowTokenRow.current_balance, selectedContractFlowTokenRow.token.decimals) }}</strong>
            </div>
            <div v-if="selectedContractFlowTokenRow" class="mini-meta">
              <span>Total Flow</span>
              <strong class="mono">{{ formatTokenAmount(selectedContractFlowTokenRow.total_token_flow, selectedContractFlowTokenRow.token.decimals) }}</strong>
            </div>
          </div>
          <div class="table-wrap">
            <table class="table-contract-flows">
              <colgroup>
                <col class="col-contract-address">
                <col class="col-flag">
                <col class="col-short">
                <col class="col-amount">
                <col class="col-short">
                <col class="col-amount">
                <col class="col-short">
                <col class="col-amount">
              </colgroup>
              <thead>
                <tr>
                  <th><button class="th-sort-btn" :class="{ active: isActiveSort('contractTokenFlows', 'counterparty') }" @click="toggleTableSort('contractTokenFlows', 'counterparty')">Counterparty <span>{{ sortIndicator('contractTokenFlows', 'counterparty') }}</span></button></th>
                  <th><button class="th-sort-btn" :class="{ active: isActiveSort('contractTokenFlows', 'kind') }" @click="toggleTableSort('contractTokenFlows', 'kind')">Kind <span>{{ sortIndicator('contractTokenFlows', 'kind') }}</span></button></th>
                  <th><button class="th-sort-btn" :class="{ active: isActiveSort('contractTokenFlows', 'in_count') }" @click="toggleTableSort('contractTokenFlows', 'in_count')">In Count <span>{{ sortIndicator('contractTokenFlows', 'in_count') }}</span></button></th>
                  <th><button class="th-sort-btn" :class="{ active: isActiveSort('contractTokenFlows', 'in_amount') }" @click="toggleTableSort('contractTokenFlows', 'in_amount')">In Amount <span>{{ sortIndicator('contractTokenFlows', 'in_amount') }}</span></button></th>
                  <th><button class="th-sort-btn" :class="{ active: isActiveSort('contractTokenFlows', 'out_count') }" @click="toggleTableSort('contractTokenFlows', 'out_count')">Out Count <span>{{ sortIndicator('contractTokenFlows', 'out_count') }}</span></button></th>
                  <th><button class="th-sort-btn" :class="{ active: isActiveSort('contractTokenFlows', 'out_amount') }" @click="toggleTableSort('contractTokenFlows', 'out_amount')">Out Amount <span>{{ sortIndicator('contractTokenFlows', 'out_amount') }}</span></button></th>
                  <th><button class="th-sort-btn" :class="{ active: isActiveSort('contractTokenFlows', 'tx_count') }" @click="toggleTableSort('contractTokenFlows', 'tx_count')">TX Count <span>{{ sortIndicator('contractTokenFlows', 'tx_count') }}</span></button></th>
                  <th><button class="th-sort-btn" :class="{ active: isActiveSort('contractTokenFlows', 'total_flow') }" @click="toggleTableSort('contractTokenFlows', 'total_flow')">Total Flow <span>{{ sortIndicator('contractTokenFlows', 'total_flow') }}</span></button></th>
                </tr>
              </thead>
              <tbody>
                <tr v-if="!selectedContractFlowTokenRow">
                  <td colspan="8" class="muted">No token selected</td>
                </tr>
                <tr v-else-if="!sortedContractTokenFlows.length">
                  <td colspan="8" class="muted">No counterparty flow for this token</td>
                </tr>
                <tr v-for="row in paginatedContractTokenFlows" :key="`${row.address || row.label}:${row.tx_count}`">
                  <td class="mono">
                    <div v-if="row.address" class="address-inline">
                      <button class="link-btn mono" @click="openContract(row.address)">{{ row.address }}</button>
                      <button class="icon-copy-btn" type="button" @click="copyAddress(row.address)" :aria-label="`Copy ${row.address}`" :title="isCopiedAddress(row.address) ? 'Copied' : 'Copy address'">
                        <svg v-if="isCopiedAddress(row.address)" viewBox="0 0 16 16" aria-hidden="true" class="icon-svg success">
                          <path d="M6.4 11.2 3.2 8l1.1-1.1 2.1 2.1 5.3-5.3L12.8 4z" fill="currentColor"></path>
                        </svg>
                        <svg v-else viewBox="0 0 16 16" aria-hidden="true" class="icon-svg">
                          <path d="M5 2.5A1.5 1.5 0 0 1 6.5 1h6A1.5 1.5 0 0 1 14 2.5v7A1.5 1.5 0 0 1 12.5 11h-1V9.5h1v-7h-6v1H5z" fill="currentColor"></path>
                          <path d="M3.5 5A1.5 1.5 0 0 0 2 6.5v7A1.5 1.5 0 0 0 3.5 15h6A1.5 1.5 0 0 0 11 13.5v-7A1.5 1.5 0 0 0 9.5 5zm0 1.5h6v7h-6z" fill="currentColor"></path>
                        </svg>
                      </button>
                    </div>
                    <span v-else>{{ row.label }}</span>
                  </td>
                  <td>
                    <span class="chip small" :class="row.is_contract ? 'ok' : 'warn'">{{ row.is_contract ? 'contract' : 'eoa pool' }}</span>
                  </td>
                  <td>{{ row.transfer_in_count }}</td>
                  <td class="mono">{{ formatTokenAmount(row.transfer_in_amount, selectedContractFlowTokenRow.token.decimals) }}</td>
                  <td>{{ row.transfer_out_count }}</td>
                  <td class="mono">{{ formatTokenAmount(row.transfer_out_amount, selectedContractFlowTokenRow.token.decimals) }}</td>
                  <td>{{ row.tx_count }}</td>
                  <td class="mono">{{ formatTokenAmount(row.total_flow, selectedContractFlowTokenRow.token.decimals) }}</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <section class="card card-wide" v-if="contractDetail">
          <div class="card-head">
            <h2>Review History</h2>
            <span class="muted">{{ contractReviews.length }} entries</span>
          </div>
          <div class="table-wrap">
            <table class="table-review-history">
              <colgroup>
                <col class="col-label-wide">
                <col class="col-pattern">
                <col class="col-flag">
                <col class="col-flag">
                <col class="col-time">
                <col class="col-review-text">
              </colgroup>
              <thead>
                <tr>
                  <th><button class="th-sort-btn" :class="{ active: isActiveSort('reviewHistory', 'label') }" @click="toggleTableSort('reviewHistory', 'label')">Label <span>{{ sortIndicator('reviewHistory', 'label') }}</span></button></th>
                  <th><button class="th-sort-btn" :class="{ active: isActiveSort('reviewHistory', 'pattern') }" @click="toggleTableSort('reviewHistory', 'pattern')">Pattern <span>{{ sortIndicator('reviewHistory', 'pattern') }}</span></button></th>
                  <th><button class="th-sort-btn" :class="{ active: isActiveSort('reviewHistory', 'status') }" @click="toggleTableSort('reviewHistory', 'status')">Status <span>{{ sortIndicator('reviewHistory', 'status') }}</span></button></th>
                  <th><button class="th-sort-btn" :class="{ active: isActiveSort('reviewHistory', 'exploitable') }" @click="toggleTableSort('reviewHistory', 'exploitable')">Exploitable <span>{{ sortIndicator('reviewHistory', 'exploitable') }}</span></button></th>
                  <th><button class="th-sort-btn" :class="{ active: isActiveSort('reviewHistory', 'updated') }" @click="toggleTableSort('reviewHistory', 'updated')">Updated <span>{{ sortIndicator('reviewHistory', 'updated') }}</span></button></th>
                  <th><button class="th-sort-btn" :class="{ active: isActiveSort('reviewHistory', 'review') }" @click="toggleTableSort('reviewHistory', 'review')">Review <span>{{ sortIndicator('reviewHistory', 'review') }}</span></button></th>
                </tr>
              </thead>
              <tbody>
                <tr v-if="!contractReviews.length">
                  <td colspan="6" class="muted">No review entries yet</td>
                </tr>
                <tr v-for="review in paginatedContractReviews" :key="`${review.id}:${review.pattern_hash}:${review.updated_at}`">
                  <td>{{ review.label || '--' }}</td>
                  <td class="mono">{{ shortAddress(review.pattern_hash, 10, 8) }}</td>
                  <td>{{ review.status }}</td>
                  <td>
                    <span class="chip small" :class="review.exploitable ? 'bad' : 'ok'">
                      {{ review.exploitable ? 'yes' : 'no' }}
                    </span>
                  </td>
                  <td>{{ formatDateTime(review.updated_at) }}</td>
                  <td>{{ review.review_text || '--' }}</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>
        </template>
      </main>

      <div v-if="contractReviewModal.open" class="modal-backdrop" @click.self="closeContractReviewModal">
        <div class="modal-card review-modal-card">
          <div class="review-modal-topbar">
            <label class="stack-label review-modal-address-field">
              <span>{{ contractReviewModal.target_kind === 'implementation' ? 'Implementation' : (contractReviewModal.target_kind === 'delegate' ? 'Delegate' : 'Contract') }}</span>
              <input :value="contractReviewSelectedTargetAddress" type="text" readonly class="code-box review-modal-code">
            </label>
            <button class="icon-action-btn review-modal-close" type="button" @click="closeContractReviewModal" aria-label="Close review modal" title="Close">
              <svg viewBox="0 0 16 16" aria-hidden="true" class="icon-svg">
                <path d="m4.2 4.2 7.6 7.6-1 1-7.6-7.6z" fill="currentColor"></path>
                <path d="m11.8 4.2-7.6 7.6-1-1 7.6-7.6z" fill="currentColor"></path>
              </svg>
            </button>
          </div>
          <div class="review-modal-body">
            <section class="review-modal-form-grid">
              <label class="stack-label review-modal-field">
                <span>Target Kind</span>
                <select v-model="contractReviewModal.target_kind" @change="syncContractReviewModalForSelectedTarget">
                  <option
                    v-for="target in contractReviewTargetOptions"
                    :key="`${target.kind}:${target.address}`"
                    :value="target.kind"
                  >
                    {{ target.kind }} | {{ target.address }}
                  </option>
                </select>
              </label>
              <label class="stack-label review-modal-field">
                <span>Label</span>
                <input v-model="contractReviewModal.label" type="text" placeholder="review label">
              </label>
              <label class="stack-label review-modal-toggle-card">
                <span>Risk Status</span>
                <span class="review-toggle-row">
                  <input v-model="contractReviewModal.exploitable" type="checkbox">
                  <strong>{{ contractReviewModal.exploitable ? 'Exploitable' : 'Review only' }}</strong>
                </span>
              </label>
              <label class="stack-label review-modal-field review-modal-field-wide">
                <span>Review Text</span>
                <textarea v-model="contractReviewModal.review_text" rows="8" class="code-box review-modal-textarea" placeholder="Summarize why this contract matters, what the pattern does, and any review outcome."></textarea>
              </label>
            </section>

            <div class="review-modal-footer">
              <p v-if="contractReviewModal.error" class="inline-error review-modal-error">{{ contractReviewModal.error }}</p>
              <div class="button-row review-modal-actions">
                <button class="btn ghost" type="button" @click="closeContractReviewModal">Cancel</button>
                <button class="btn primary" type="button" :disabled="contractReviewModal.saving" @click="saveContractReviewModal">
                  {{ contractReviewModal.saving ? 'Saving...' : 'Save Review' }}
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div v-if="contractLinkageModal.open" class="modal-backdrop" @click.self="closeContractLinkageModal">
        <div class="modal-card review-modal-card">
          <div class="review-modal-topbar">
            <label class="stack-label review-modal-address-field">
              <span>Contract</span>
              <input :value="contractDetail?.address || ''" type="text" readonly class="code-box review-modal-code">
            </label>
            <button class="icon-action-btn review-modal-close" type="button" @click="closeContractLinkageModal" aria-label="Close impl modal" title="Close">
              <svg viewBox="0 0 16 16" aria-hidden="true" class="icon-svg">
                <path d="M4.2 3.2 8 7l3.8-3.8 1 1L9 8l3.8 3.8-1 1L8 9l-3.8 3.8-1-1L7 8 3.2 4.2z" fill="currentColor"></path>
              </svg>
            </button>
          </div>
          <div class="review-modal-body">
            <section class="review-modal-form-grid">
              <label class="stack-label review-modal-field">
                <span>Link Type</span>
                <select v-model="contractLinkageModal.link_type">
                  <option value="">Plain Contract</option>
                  <option value="proxy">Proxy</option>
                  <option value="eip7702">EIP-7702</option>
                </select>
              </label>
              <label class="stack-label review-modal-field review-modal-field-wide">
                <span>Implementation</span>
                <input
                  v-model="contractLinkageModal.linkage"
                  type="text"
                  class="code-box review-modal-code"
                  :disabled="!contractLinkageModal.link_type"
                  placeholder="0x implementation address"
                >
              </label>
            </section>
            <p class="muted review-modal-helper">
              Saving linkage also updates the contract's effective pattern target so the detail view, reviews, and pending sync pattern rows stay aligned.
            </p>
            <div class="review-modal-footer">
              <p v-if="contractLinkageModal.error" class="inline-error review-modal-error">{{ contractLinkageModal.error }}</p>
              <div class="button-row review-modal-actions">
                <button class="btn ghost" type="button" @click="closeContractLinkageModal">Cancel</button>
                <button class="btn primary" type="button" :disabled="contractLinkageModal.saving" @click="saveContractLinkageModal">
                  {{ contractLinkageModal.saving ? 'Saving...' : 'Save Impl' }}
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div v-if="tokenReviewModal.open" class="modal-backdrop" @click.self="closeTokenReviewModal">
        <div class="modal-card review-modal-card">
          <div class="review-modal-topbar">
            <label class="stack-label review-modal-address-field">
              <span>Token</span>
              <input :value="tokenReviewModal.address" type="text" readonly class="code-box review-modal-code">
            </label>
            <button class="icon-action-btn review-modal-close" type="button" @click="closeTokenReviewModal" aria-label="Close token review modal" title="Close">
              <svg viewBox="0 0 16 16" aria-hidden="true" class="icon-svg">
                <path d="m4.2 4.2 7.6 7.6-1 1-7.6-7.6z" fill="currentColor"></path>
                <path d="m11.8 4.2-7.6 7.6-1-1 7.6-7.6z" fill="currentColor"></path>
              </svg>
            </button>
          </div>
          <div class="review-modal-body">
            <section class="review-modal-form-grid">
              <label class="stack-label review-modal-field review-modal-field-wide">
                <span>Review Text</span>
                <textarea v-model="tokenReviewModal.review_text" rows="8" class="code-box review-modal-textarea" placeholder="Summarize token-level risks, exploitability, and any context worth preserving for later review."></textarea>
              </label>
              <label class="stack-label review-modal-toggle-card review-modal-field-wide">
                <span>Risk Status</span>
                <span class="review-toggle-row">
                  <input v-model="tokenReviewModal.exploitable" type="checkbox">
                  <strong>{{ tokenReviewModal.exploitable ? 'Exploitable' : 'Review only' }}</strong>
                </span>
              </label>
            </section>

            <div class="review-modal-footer">
              <p v-if="tokenReviewModal.error" class="inline-error review-modal-error">{{ tokenReviewModal.error }}</p>
              <div class="button-row review-modal-actions">
                <button class="btn ghost" type="button" @click="closeTokenReviewModal">Cancel</button>
                <button class="btn primary" type="button" :disabled="tokenReviewModal.saving" @click="saveTokenReviewModal">
                  {{ tokenReviewModal.saving ? 'Saving...' : 'Save Review' }}
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script src="/vendor/vue.global.prod.js"></script>
    <script src="/vendor/vue-router.global.prod.js"></script>
    <script src="/vendor/pinia.iife.prod.js"></script>
    <script src="/js/dashboard-shared.js"></script>
    <script src="/js/dashboard-runtime.js"></script>
    <script src="/js/dashboard-scroll-sync.js"></script>
    <script src="/js/dashboard-table-state.js"></script>
    <script src="/js/dashboard-view-state.js"></script>
    <script src="/js/dashboard-loaders.js"></script>
    <script src="/js/dashboard-actions.js"></script>
    <script src="/js/dashboard-modals.js"></script>
    <script src="/js/dashboard-routing.js"></script>
    <script src="/js/dashboard.js" defer></script>
  </body>
</html>
