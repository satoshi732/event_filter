<!doctype html>
<html lang="en">
  <head>
    <%- await include('../partials/head', { title: title || 'Solana Mev Labs' }) %>
  </head>
  <body
    data-initial-view="<%= initialView || 'dashboard' %>"
    data-auth-enabled="<%= authEnabled ? '1' : '0' %>"
    data-current-user="<%= currentUser || '' %>"
  >
    <div id="app" class="app-shell" v-cloak>
      <div v-if="notifications.length" class="toast-stack" aria-live="polite" aria-atomic="true">
        <div v-for="toast in notifications" :key="toast.id" class="toast-card" :class="`toast-${toast.tone || 'info'}`">
          <div class="toast-copy">
            <strong class="toast-title">{{ toast.tone === 'error' ? 'Error' : toast.tone === 'warning' ? 'Notice' : 'Update' }}</strong>
            <span>{{ toast.message }}</span>
          </div>
          <button class="toast-close" type="button" @click="dismissNotification(toast.id)" aria-label="Dismiss notification" title="Dismiss">
            <svg viewBox="0 0 16 16" class="icon-svg" aria-hidden="true">
              <path d="m4.2 4.2 7.6 7.6-1 1-7.6-7.6z" fill="currentColor"></path>
              <path d="m11.8 4.2-7.6 7.6-1-1 7.6-7.6z" fill="currentColor"></path>
            </svg>
          </button>
        </div>
      </div>
      <header class="hero">
        <div class="hero-top">
          <div>
            <p class="kicker">Event Filter Control</p>
            <h1 class="hero-title">Solana Mev Labs</h1>
          </div>
          <div class="hero-actions">
            <label class="inline-label">
              <span>Chain</span>
              <select v-model="selectedChain" @change="handleChainChanged">
                <option v-for="chain in chains" :key="chain" :value="chain">{{ chain.toUpperCase() }}</option>
              </select>
            </label>
            <button class="btn primary" type="button" :disabled="running || !selectedChain" @click="runScan">
              {{ running ? 'Running...' : 'Run Round' }}
            </button>
            <button class="btn ghost" type="button" @click="refreshCurrent">Refresh</button>
            <div v-if="authEnabled" class="session-chip">
              <span class="mono">{{ currentUser || 'signed in' }}</span>
              <button class="btn ghost btn-small" type="button" @click="logout">Sign Out</button>
            </div>
          </div>
        </div>

        <div class="hero-meta">
          <span class="mono">{{ runMetaText }}</span>
        </div>

        <section v-if="running && progress" class="hero-progress">
          <div class="hero-progress-head">
            <div>
              <p class="hero-progress-stage">{{ progressStageLabel }}</p>
              <strong>{{ progressLabel }}</strong>
            </div>
            <div class="hero-progress-meta">
              <span class="chip small" :class="progressStatusTone">{{ progressPercent }}%</span>
              <span v-if="progressDetailText" class="mono">{{ progressDetailText }}</span>
            </div>
          </div>
          <div class="progress-track" aria-hidden="true">
            <div class="progress-fill" :style="{ width: `${progressPercent}%` }"></div>
          </div>
        </section>

        <div class="hero-nav-row">
          <div class="hero-nav">
            <button class="tab" :class="{ active: currentView === 'dashboard' && dashboardTab === 'tokens' }" @click="openDashboardMain">Dashboard</button>
            <button class="tab" :class="{ active: currentView === 'dashboard' && dashboardTab === 'auto' }" @click="openAutoMode">Auto Mode</button>
            <button class="tab" :class="{ active: currentView === 'token' || currentView === 'token-detail' }" @click="navigateToken">Token</button>
            <button class="tab" :class="{ active: currentView === 'dashboard' && dashboardTab === 'settings' }" @click="openSettings">Settings</button>
          </div>
          <div class="hero-status-badges">
            <span class="status-badge" :class="syncStatus?.configured ? 'active' : 'inactive'">AUTO SYNC</span>
            <span class="status-badge" :class="autoAnalysisEnabled ? 'active' : 'inactive'">AUTO AUDIT</span>
          </div>
        </div>
      </header>

      <main v-if="currentView === 'dashboard'" class="grid dashboard-grid">
        <template v-if="pageLoading">
          <section class="card card-full skeleton-card">
            <div class="skeleton-block skeleton-heading"></div>
            <div class="meta-grid skeleton-meta-grid">
              <div v-for="n in 4" :key="`dashboard-meta-skeleton-${n}`" class="meta-item skeleton-meta-item">
                <div class="skeleton-block skeleton-label"></div>
                <div class="skeleton-block skeleton-value"></div>
              </div>
            </div>
          </section>
          <section class="card card-full skeleton-card">
            <div class="card-head">
              <div class="skeleton-block skeleton-heading"></div>
              <div class="skeleton-block skeleton-inline"></div>
            </div>
            <div class="filter-toolbar dense">
              <div class="skeleton-block skeleton-input grow"></div>
              <div class="skeleton-block skeleton-input"></div>
              <div class="skeleton-block skeleton-input"></div>
            </div>
            <div class="table-wrap skeleton-table-wrap">
              <div class="skeleton-table">
                <div v-for="n in 8" :key="`dashboard-row-skeleton-${n}`" class="skeleton-table-row">
                  <div v-for="m in 6" :key="`dashboard-cell-skeleton-${n}-${m}`" class="skeleton-block skeleton-cell"></div>
                </div>
              </div>
            </div>
          </section>
        </template>

        <template v-else-if="dashboardTab === 'tokens'">
        <section class="card card-full">
          <div class="meta-grid">
            <div class="meta-item">
              <span>Total Contracts</span>
              <strong>{{ getTablePaginationMeta('contractOverview').totalRows }}</strong>
            </div>
            <div class="meta-item">
              <span>Exploitable Tagged</span>
              <strong>{{ exploitableCount }}</strong>
            </div>
            <div class="meta-item">
              <span>Top Total USD</span>
              <strong>{{ formatUsd(topPortfolioUsd) }}</strong>
            </div>
            <div class="meta-item">
              <span>Pattern Sync Queue</span>
              <strong>{{ syncMetaText }}</strong>
            </div>
          </div>
        </section>

        <section class="card card-full">
          <div class="card-head">
            <h2>Contract Overview</h2>
            <span class="muted">
              {{ getTablePaginationMeta('contractOverview').totalRows ? `${getTablePaginationMeta('contractOverview').start}-${getTablePaginationMeta('contractOverview').end} / ${getTablePaginationMeta('contractOverview').totalRows}` : '0 / 0' }} contracts
            </span>
          </div>
          <div class="filter-toolbar dense">
            <label class="filter-field grow">
              <span>Search</span>
              <input v-model="dashboardFilters.contractQuery" type="text" placeholder="contract, linkage, pattern">
            </label>
            <label class="filter-field">
              <span>Risk</span>
              <select v-model="dashboardFilters.contractRisk">
                <option value="all">All</option>
                <option value="exploitable">Exploitable</option>
                <option value="seen">Seen</option>
                <option value="unseen">Unseen</option>
              </select>
            </label>
            <label class="filter-field">
              <span>Link</span>
              <select v-model="dashboardFilters.contractLinkType">
                <option value="all">All</option>
                <option value="plain">Plain</option>
                <option value="proxy">Proxy</option>
                <option value="eip7702">EIP-7702</option>
              </select>
            </label>
          </div>
          <div class="table-wrap contract-overview-wrap">
            <table class="contract-overview-grid">
              <colgroup>
                <col class="overview-col-contract">
                <col class="overview-col-label">
                <col class="overview-col-usd">
                <col class="overview-col-linkage">
                <col class="overview-col-patterns">
                <col class="overview-col-deployed">
                <col class="overview-col-flag">
                <col class="overview-col-audit-result">
                <col class="overview-col-action">
              </colgroup>
              <thead>
                <tr>
                  <th><button class="th-sort-btn" :class="{ active: isActiveSort('contractOverview', 'contract') }" @click="toggleTableSort('contractOverview', 'contract')">Contract <span>{{ sortIndicator('contractOverview', 'contract') }}</span></button></th>
                  <th><button class="th-sort-btn" :class="{ active: isActiveSort('contractOverview', 'label') }" @click="toggleTableSort('contractOverview', 'label')">Label <span>{{ sortIndicator('contractOverview', 'label') }}</span></button></th>
                  <th><button class="th-sort-btn" :class="{ active: isActiveSort('contractOverview', 'total_usd') }" @click="toggleTableSort('contractOverview', 'total_usd')">Total USD <span>{{ sortIndicator('contractOverview', 'total_usd') }}</span></button></th>
                  <th><button class="th-sort-btn" :class="{ active: isActiveSort('contractOverview', 'linkage') }" @click="toggleTableSort('contractOverview', 'linkage')">Linkage <span>{{ sortIndicator('contractOverview', 'linkage') }}</span></button></th>
                  <th><button class="th-sort-btn" :class="{ active: isActiveSort('contractOverview', 'patterns') }" @click="toggleTableSort('contractOverview', 'patterns')">Patterns <span>{{ sortIndicator('contractOverview', 'patterns') }}</span></button></th>
                  <th><button class="th-sort-btn" :class="{ active: isActiveSort('contractOverview', 'deployed') }" @click="toggleTableSort('contractOverview', 'deployed')">Deployed <span>{{ sortIndicator('contractOverview', 'deployed') }}</span></button></th>
                  <th><button class="th-sort-btn" :class="{ active: isActiveSort('contractOverview', 'auto_audit_status') }" @click="toggleTableSort('contractOverview', 'auto_audit_status')">Auto Audit <span>{{ sortIndicator('contractOverview', 'auto_audit_status') }}</span></button></th>
                  <th><button class="th-sort-btn" :class="{ active: isActiveSort('contractOverview', 'audit_result') }" @click="toggleTableSort('contractOverview', 'audit_result')">Audit Result <span>{{ sortIndicator('contractOverview', 'audit_result') }}</span></button></th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <tr v-if="!filteredContracts.length">
                  <td colspan="9" class="muted">No contract data</td>
                </tr>
                <template v-for="section in contractOverviewSections" :key="section.key">
                  <tr v-if="section.isGrouped" class="pattern-section-row" :class="section.toneClass">
                    <td colspan="9">
                      <button class="pattern-section-head pattern-section-toggle" type="button" @click="toggleGroupCollapse('contractOverview', section.key)">
                        <strong>{{ section.title }}</strong>
                        <span class="pattern-section-meta">
                          <span class="chip small">{{ section.rows.length }} contracts</span>
                          <span class="collapse-icon" :class="{ collapsed: section.collapsed }" aria-hidden="true">
                            <svg viewBox="0 0 16 16" class="icon-svg">
                              <path d="M4.6 6.2 8 9.6l3.4-3.4 1 1L8 11.6 3.6 7.2z" fill="currentColor"></path>
                            </svg>
                          </span>
                        </span>
                      </button>
                    </td>
                  </tr>
                  <tr v-for="row in section.rows" v-show="!section.collapsed" :key="row.contract" :class="[contractToneClass(row), section.isGrouped ? 'pattern-section-member' : '']">
                  <td>
                    <div class="address-inline">
                      <button class="link-btn mono" @click="openContract(row.contract)">{{ row.contract }}</button>
                      <button class="icon-copy-btn" type="button" @click="copyAddress(row.contract)" :aria-label="`Copy ${row.contract}`" :title="isCopiedAddress(row.contract) ? 'Copied' : 'Copy address'">
                        <svg v-if="isCopiedAddress(row.contract)" viewBox="0 0 16 16" aria-hidden="true" class="icon-svg success">
                          <path d="M6.4 11.2 3.2 8l1.1-1.1 2.1 2.1 5.3-5.3L12.8 4z" fill="currentColor"></path>
                        </svg>
                        <svg v-else viewBox="0 0 16 16" aria-hidden="true" class="icon-svg">
                          <path d="M5 2.5A1.5 1.5 0 0 1 6.5 1h6A1.5 1.5 0 0 1 14 2.5v7A1.5 1.5 0 0 1 12.5 11h-1V9.5h1v-7h-6v1H5z" fill="currentColor"></path>
                          <path d="M3.5 5A1.5 1.5 0 0 0 2 6.5v7A1.5 1.5 0 0 0 3.5 15h6A1.5 1.5 0 0 0 11 13.5v-7A1.5 1.5 0 0 0 9.5 5zm0 1.5h6v7h-6z" fill="currentColor"></path>
                        </svg>
                      </button>
                    </div>
                  </td>
                  <td>{{ row.label || '--' }}</td>
                  <td>{{ formatUsd(row.portfolio_usd) }}</td>
                  <td class="mono">
                    <div v-if="row.linkage" class="address-inline">
                      <span>{{ row.linkage }}</span>
                      <button class="icon-copy-btn" type="button" @click="copyAddress(row.linkage)" :aria-label="`Copy ${row.linkage}`" :title="isCopiedAddress(row.linkage) ? 'Copied' : 'Copy address'">
                        <svg v-if="isCopiedAddress(row.linkage)" viewBox="0 0 16 16" aria-hidden="true" class="icon-svg success">
                          <path d="M6.4 11.2 3.2 8l1.1-1.1 2.1 2.1 5.3-5.3L12.8 4z" fill="currentColor"></path>
                        </svg>
                        <svg v-else viewBox="0 0 16 16" aria-hidden="true" class="icon-svg">
                          <path d="M5 2.5A1.5 1.5 0 0 1 6.5 1h6A1.5 1.5 0 0 1 14 2.5v7A1.5 1.5 0 0 1 12.5 11h-1V9.5h1v-7h-6v1H5z" fill="currentColor"></path>
                          <path d="M3.5 5A1.5 1.5 0 0 0 2 6.5v7A1.5 1.5 0 0 0 3.5 15h6A1.5 1.5 0 0 0 11 13.5v-7A1.5 1.5 0 0 0 9.5 5zm0 1.5h6v7h-6z" fill="currentColor"></path>
                        </svg>
                      </button>
                    </div>
                    <span v-else>--</span>
                  </td>
                  <td>
                    <div v-if="row.patterns?.length" class="pattern-chip-list">
                      <span v-for="pattern in row.patterns" :key="`${row.contract}:${pattern}`" class="chip small pattern-chip">
                        {{ pattern }}
                      </span>
                    </div>
                    <span v-else class="muted">--</span>
                  </td>
                  <td :title="formatDateTime(row.deployed_at)">{{ formatRelativeTime(row.deployed_at) }}</td>
                  <td>
                    <span class="chip small" :class="autoAuditStatusTone(autoAuditStatusLabel(row.auto_audit_status))">
                      {{ autoAuditStatusLabel(row.auto_audit_status) }}
                    </span>
                  </td>
                  <td>
                    <span v-if="autoAuditStatusLabel(row.auto_audit_status) === 'yes'" class="audit-severity-badge">
                      <span v-for="entry in auditSeverityPills(row)" :key="`${row.contract}:${entry.key}`" class="audit-severity-fragment" :class="entry.className">
                        <span class="audit-severity-label">{{ entry.shortLabel }}</span><span class="audit-severity-value">{{ entry.count }}</span>
                      </span>
                    </span>
                    <span v-else class="muted">--</span>
                  </td>
                  <td>
                    <div class="icon-action-row">
                      <button
                        class="icon-action-btn"
                        type="button"
                        @click="openContractReviewModal(row, 'overview')"
                        :aria-label="`Open review for ${row.contract}`"
                        title="Add review"
                      >
                        <svg viewBox="0 0 16 16" aria-hidden="true" class="icon-svg">
                          <path d="M3 2.5A1.5 1.5 0 0 1 4.5 1h5.8a1.5 1.5 0 0 1 1.06.44l1.2 1.2A1.5 1.5 0 0 1 13 3.7v8.8A1.5 1.5 0 0 1 11.5 14h-7A1.5 1.5 0 0 1 3 12.5zm1.5 0v10h7V4.2l-.7-.7H4.5zm1.2 2.3h4.6v1H5.7zm0 2h4.6v1H5.7zm0 2h3v1h-3z" fill="currentColor"></path>
                        </svg>
                      </button>
                      <button
                        v-if="canRequestOverviewAutoAudit(row)"
                        class="icon-action-btn"
                        type="button"
                        @click="requestOverviewAutoAudit(row)"
                        :aria-label="`Request AI auto audit for ${row.contract}`"
                        title="Request AI auto audit"
                      >
                        <svg viewBox="0 0 16 16" aria-hidden="true" class="icon-svg">
                          <path d="M8 1.2 9.4 5l3.8 1.4L9.4 7.8 8 11.6 6.6 7.8 2.8 6.4 6.6 5z" fill="currentColor"></path>
                          <path d="M12 9.8 12.7 11.6 14.5 12.3 12.7 13 12 14.8 11.3 13 9.5 12.3 11.3 11.6z" fill="currentColor"></path>
                        </svg>
                      </button>
                      <span v-else-if="autoAuditStatusLabel(row.auto_audit_status) === 'processing'" class="chip small warn">processing</span>
                      <span v-else class="muted">--</span>
                    </div>
                  </td>
                  </tr>
                </template>
              </tbody>
            </table>
          </div>
          <div class="table-pagination" v-if="getTablePaginationMeta('contractOverview').totalRows > 0">
            <div class="table-pagination-meta">
              <span class="mono tiny-muted">Page {{ getTablePaginationMeta('contractOverview').page }} / {{ getTablePaginationMeta('contractOverview').totalPages }}</span>
              <span class="muted">{{ getTablePaginationMeta('contractOverview').start }}-{{ getTablePaginationMeta('contractOverview').end }} / {{ getTablePaginationMeta('contractOverview').totalRows }}</span>
            </div>
            <div class="table-pagination-controls">
              <div class="page-size-group" role="group" aria-label="Contract overview page size">
                <button
                  v-for="size in pageSizeOptions"
                  :key="`contractOverview-size-${size}`"
                  class="page-size-btn"
                  :class="{ active: getTablePageSize('contractOverview') === size }"
                  type="button"
                  @click="setTablePageSize('contractOverview', size)"
                >
                  {{ size }}
                </button>
              </div>
              <div class="page-nav-group">
                <button class="btn ghost btn-small" type="button" :disabled="getTablePaginationMeta('contractOverview').page <= 1" @click="goToTablePage('contractOverview', 1)">First</button>
                <button class="btn ghost btn-small" type="button" :disabled="!canMoveTablePage('contractOverview', -1)" @click="moveTablePage('contractOverview', -1)">Prev</button>
                <div class="page-number-group">
                  <template v-for="(pageItem, pageIndex) in getTablePageButtons('contractOverview')" :key="`contractOverview-page-${pageIndex}-${pageItem}`">
                    <span v-if="pageItem === 'ellipsis'" class="page-ellipsis">…</span>
                    <button
                      v-else
                      class="page-number-btn"
                      :class="{ active: getTablePaginationMeta('contractOverview').page === pageItem }"
                      type="button"
                      @click="goToTablePage('contractOverview', pageItem)"
                    >
                      {{ pageItem }}
                    </button>
                  </template>
                </div>
                <button class="btn ghost btn-small" type="button" :disabled="!canMoveTablePage('contractOverview', 1)" @click="moveTablePage('contractOverview', 1)">Next</button>
                <button class="btn ghost btn-small" type="button" :disabled="getTablePaginationMeta('contractOverview').page >= getTablePaginationMeta('contractOverview').totalPages" @click="goToTablePage('contractOverview', getTablePaginationMeta('contractOverview').totalPages)">Last</button>
              </div>
            </div>
          </div>
        </section>
        </template>

        <section class="card card-full" v-else-if="dashboardTab === 'auto' && !pageLoading">
          <div class="card-head">
            <h2>Auto Analysis Engine</h2>
            <span class="muted">Run and tune unattended analysis from one place</span>
          </div>

          <div class="auto-mode-console">
            <section class="auto-board-top">
              <div class="auto-command-center">
                <div class="auto-board-kicker-row">
                  <p class="kicker">Unattended Audit Loop</p>
                  <span class="chip small" :class="autoAnalysisChipTone">{{ autoAnalysisEnabled ? 'AUTO ON' : 'AUTO OFF' }}</span>
                </div>
                <h3>Night Shift Operations</h3>
                <p class="muted auto-mode-status-text">{{ autoAnalysisDetailText }}</p>
                <div class="auto-command-strip">
                  <div class="auto-command-item">
                    <span>Target Chain</span>
                    <strong>{{ (autoAnalysisStatus.chain || selectedChain || '--').toUpperCase() }}</strong>
                  </div>
                  <div class="auto-command-item">
                    <span>Phase</span>
                    <strong>{{ autoAnalysisStatus.phase || 'idle' }}</strong>
                  </div>
                  <div class="auto-command-item">
                    <span>Queued</span>
                    <strong>{{ autoAnalysisStatus.queued || 0 }}</strong>
                  </div>
                </div>
                <div class="button-row">
                  <button
                    class="btn"
                    :class="autoAnalysisEnabled ? 'secondary' : 'primary'"
                    type="button"
                    :disabled="!selectedChain && !autoAnalysisEnabled"
                    @click="toggleAutoAnalysis"
                  >
                    {{ autoAnalysisButtonLabel }}
                  </button>
                </div>
              </div>

              <div class="auto-telemetry-panel">
                <div class="auto-telemetry-grid">
                  <div class="auto-telemetry-card">
                    <span>Pool Capacity</span>
                    <strong>{{ autoAnalysisStatus.capacity || settings.runtime_settings.auto_analysis.queue_capacity || 10 }}</strong>
                  </div>
                  <div class="auto-telemetry-card">
                    <span>Running Now</span>
                    <strong>{{ autoAnalysisStatus.active || 0 }}</strong>
                  </div>
                  <div class="auto-telemetry-card">
                    <span>Token Share</span>
                    <strong>{{ settings.runtime_settings.auto_analysis.token_share_percent || 0 }}%</strong>
                  </div>
                  <div class="auto-telemetry-card">
                    <span>Contract Share</span>
                    <strong>{{ settings.runtime_settings.auto_analysis.contract_share_percent || 0 }}%</strong>
                  </div>
                  <div class="auto-telemetry-card">
                    <span>Audit Provider</span>
                    <strong>{{ settings.runtime_settings.auto_analysis.provider || '--' }}</strong>
                  </div>
                  <div class="auto-telemetry-card">
                    <span>Audit Model</span>
                    <strong>{{ settings.runtime_settings.auto_analysis.model || '--' }}</strong>
                  </div>
                </div>
              </div>
            </section>

            <section class="auto-strategy-board">
              <div class="auto-strategy-card">
                <div class="card-head compact">
                  <h3>Queue Strategy</h3>
                  <span class="muted">How the pool is split and filled</span>
                </div>
                <div class="auto-mix-strip">
                  <div class="auto-mix-bar">
                    <div class="auto-mix-token" :style="{ width: `${Math.max(0, Math.min(100, settings.runtime_settings.auto_analysis.token_share_percent || 0))}%` }"></div>
                    <div class="auto-mix-contract" :style="{ width: `${Math.max(0, Math.min(100, settings.runtime_settings.auto_analysis.contract_share_percent || 0))}%` }"></div>
                  </div>
                  <div class="auto-mix-legend">
                    <span class="chip small token-tone">Token {{ settings.runtime_settings.auto_analysis.token_share_percent || 0 }}%</span>
                    <span class="chip small contract-tone">Contract {{ settings.runtime_settings.auto_analysis.contract_share_percent || 0 }}%</span>
                  </div>
                </div>
                <div class="auto-strategy-grid">
                  <label class="stack-label">
                    <span>Queue Capacity</span>
                    <input v-model.number="settings.runtime_settings.auto_analysis.queue_capacity" type="number" min="1" max="50">
                  </label>
                  <label class="stack-label">
                    <span>Round Audit Limit</span>
                    <input v-model.number="settings.runtime_settings.auto_analysis.round_audit_limit" type="number" min="1" max="200">
                  </label>
                  <label class="stack-label">
                    <span>Round Rest (sec)</span>
                    <input v-model.number="settings.runtime_settings.auto_analysis.round_rest_seconds" type="number" min="1" max="3600">
                  </label>
                  <label class="stack-label">
                    <span>Stop At (local)</span>
                    <input v-model="settings.runtime_settings.auto_analysis.stop_at_datetime" type="datetime-local">
                  </label>
                  <label class="stack-label">
                    <span>Token Share (%)</span>
                    <input v-model.number="settings.runtime_settings.auto_analysis.token_share_percent" type="number" min="0" max="100">
                  </label>
                  <label class="stack-label">
                    <span>Contract Share (%)</span>
                    <input v-model.number="settings.runtime_settings.auto_analysis.contract_share_percent" type="number" min="0" max="100">
                  </label>
                  <label class="stack-label">
                    <span>Auto Audit Provider</span>
                    <select v-model="settings.runtime_settings.auto_analysis.provider">
                      <option v-for="provider in autoAnalysisProviderOptions" :key="`auto-provider-${provider}`" :value="provider">{{ provider }}</option>
                    </select>
                  </label>
                  <label class="stack-label">
                    <span>Auto Audit Model</span>
                    <select v-model="settings.runtime_settings.auto_analysis.model">
