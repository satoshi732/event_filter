                      <input v-model.number="settings.runtime_settings.auto_analysis.contract_min_tvl_usd" type="number" min="0" step="1000">
                    </label>
                  </div>
                  <div class="auto-threshold-box">
                    <span>Token Min Price</span>
                    <label class="stack-label compact-stack">
                      <input v-model.number="settings.runtime_settings.auto_analysis.token_min_price_usd" type="number" min="0" step="0.0001">
                    </label>
                  </div>
                </div>
              </div>
            </section>

            <section class="auto-rules-board">
