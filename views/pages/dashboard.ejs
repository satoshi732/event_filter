                      <strong>Require contract selectors</strong>
                      <p>Only queue contracts that already have selector fingerprints.</p>
                    </div>
                  </label>
                  <label class="auto-rule-item">
                    <input v-model="settings.runtime_settings.auto_analysis.skip_seen_contracts" type="checkbox">
                    <div class="auto-rule-copy">
                      <strong>Skip seen contract patterns</strong>
                      <p>Ignore contracts already mapped to known seen patterns.</p>
                    </div>
                  </label>
                  <label class="auto-rule-item">
                    <input v-model="settings.runtime_settings.auto_analysis.one_per_contract_pattern" type="checkbox">
                    <div class="auto-rule-copy">
